# Rast-CLI environment configuration
# Copy this file to .env and fill in your values, or export these in your shell.

# OpenRouter API key (required only when using the openrouter provider)
OPENROUTER_API_KEY=

# Optional: override the Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Optional: default provider on startup (ollama | openrouter)
RAST_PROVIDER=ollama

# Optional: default model on startup
RAST_MODEL=llama3
